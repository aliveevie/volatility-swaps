# Copy to .env and fill in. Never commit .env.

# ── Contracts deploy (used by: cd contracts && forge script ...) ──────────────
# PRIVATE_KEY=0x...
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Frontend (set after deploying contracts to Sepolia) ──────────────────────

# Core contracts (deployed by Deploy.s.sol)
VITE_VOLSWAP_HOOK_ADDRESS=
VITE_VOLSWAP_CALLBACK_ADDRESS=

# PoolManager on Sepolia (Uniswap v4 canonical)
VITE_POOL_MANAGER_ADDRESS=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543

# Router contracts (deployed by DeployTestRouter.s.sol)
VITE_SWAP_ROUTER_ADDRESS=
VITE_LIQUIDITY_ROUTER_ADDRESS=

# Pool token (currency1, deployed by CreatePool.s.sol or externally)
VITE_TOKEN1_ADDRESS=

# Chainlink ETH/USD price feed on Sepolia
VITE_CHAINLINK_ETH_USD_FEED=0x694AA1769357215DE4FAC081bf1f309aDC325306
